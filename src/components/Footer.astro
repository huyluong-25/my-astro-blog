<style>
	.apple-footer {
		padding: 4em 1em;
		background: linear-gradient(180deg, rgba(2, 132, 199, 0.06) 0%, rgba(248, 250, 252, 1) 100%);
		text-align: center;
		font-family: var(--font-main);
		transition: background 0.3s;
	}

	:global([data-theme='dark']) .apple-footer {
		background: linear-gradient(180deg, rgba(30, 41, 59, 0.5) 0%, rgba(15, 23, 42, 1) 100%);
	}

	.copyright {
		color: #64748b;
		font-size: 0.9rem;
		margin-bottom: 2rem;
		letter-spacing: 0.5px;
		transition: color 0.3s;
	}

	:global([data-theme='dark']) .copyright {
		color: #cbd5e1;
	}

	.social-links {
		display: flex;
		justify-content: center;
		gap: 2rem;
	}

	.glass-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 52px;
		height: 52px;
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.4);
		backdrop-filter: blur(12px) saturate(180%);
		-webkit-backdrop-filter: blur(12px) saturate(180%);
		border: 1px solid rgba(255, 255, 255, 0.6);
		color: #475569;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		box-shadow: 
			inset 0 1px 1px rgba(255, 255, 255, 0.8),
			0 10px 20px rgba(0, 0, 0, 0.05);
		text-decoration: none;
	}

	:global([data-theme='dark']) .glass-icon {
		background: rgba(30, 41, 59, 0.6);
		border-color: rgba(255, 255, 255, 0.1);
		color: #cbd5e1;
		box-shadow: 
			inset 0 1px 1px rgba(255, 255, 255, 0.2),
			0 10px 20px rgba(0, 0, 0, 0.3);
	}

	.glass-icon:hover {
		transform: translateY(-8px) scale(1.15);
		background: rgba(255, 255, 255, 0.6);
		color: #0284c7;
		box-shadow: 
			inset 0 1px 1px rgba(255, 255, 255, 0.9),
			0 20px 35px rgba(0, 0, 0, 0.1);
	}

	:global([data-theme='dark']) .glass-icon:hover {
		background: rgba(30, 41, 59, 0.8);
		color: #38bdf8;
		box-shadow: 
			inset 0 1px 1px rgba(255, 255, 255, 0.3),
			0 20px 35px rgba(0, 0, 0, 0.4);
	}

	.glass-icon svg {
		transition: transform 0.3s ease;
	}

	.glass-icon:hover svg {
		transform: rotate(8deg);
	}

	@media (max-width: 768px) {
		.apple-footer { padding: 3em 1em; }
		.glass-icon { width: 46px; height: 46px; }
	}
</style>