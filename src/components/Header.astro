---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="apple-header">
	<nav>
		<h2 class="logo"><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/huyluong-25" target="_blank" class="glass-icon-nav">
				<svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	/* HEADER LIQUID GLASS STYLE */
	header {
		margin: 0;
		padding: 0 1em;
		/* Hiệu ứng kính mờ đặc trưng Apple */
		background: rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(12px) saturate(180%);
		-webkit-backdrop-filter: blur(12px) saturate(180%);
		
		/* Giữ header luôn ở trên cùng khi cuộn trang */
		position: sticky;
		top: 0;
		z-index: 1000;
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		height: 64px;
	}

	.logo a {
		font-family: 'Arial', sans-serif !important;
		font-weight: 800;
		font-size: 1.2rem;
		color: #1e293b;
		text-decoration: none;
		letter-spacing: -0.5px;
	}

	.internal-links {
		display: flex;
		gap: 5px;
	}

	/* Style cho các link điều hướng */
	.internal-links a {
		padding: 8px 16px;
		color: #64748b;
		text-decoration: none;
		font-family: 'Arial', sans-serif !important;
		font-size: 0.95rem;
		font-weight: 500;
		border-radius: 20px;
		transition: all 0.3s ease;
	}

	/* Hiệu ứng khi Link đang active hoặc hover */
	.internal-links a:hover,
	.internal-links a.active {
		color: #0284c7;
		background: rgba(2, 132, 199, 0.08);
	}

	/* Icon GitHub góc phải */
	.glass-icon-nav {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 12px;
		background: rgba(0, 0, 0, 0.03);
		color: #475569;
		transition: all 0.3s ease;
		text-decoration: none;
	}

	.glass-icon-nav:hover {
		transform: scale(1.1) rotate(5deg);
		background: rgba(0, 0, 0, 0.06);
		color: #000;
	}

	/* Tối ưu Mobile (iPhone/iPad) */
	@media (max-width: 720px) {
		.social-links {
			display: none; /* Ẩn bớt cho gọn màn hình nhỏ */
		}
		nav {
			height: 56px;
		}
		.logo a {
			font-size: 1rem;
		}
		.internal-links a {
			padding: 6px 12px;
			font-size: 0.85rem;
		}
	}
</style>