---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="apple-header">
	<nav>
		<h2 class="logo"><a href="/">{SITE_TITLE}</a></h2>
		
		<div class="internal-links" id="navLinks">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/hoc-tieng-anh">English</HeaderLink>
			<HeaderLink href="/toeic">TOEIC</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>

		<div class="social-links">
			<button id="themeToggle" class="theme-btn" aria-label="Toggle theme">
				<span class="sun">☀️</span>
				<span class="moon">🌙</span>
			</button>

			<a href="https://github.com/huyluong-25" target="_blank" class="glass-icon-nav">
				<svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>

			<button id="menuToggle" class="menu-btn" aria-label="Toggle menu">
				<span class="hamburger-line"></span>
				<span class="hamburger-line"></span>
				<span class="hamburger-line"></span>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	// Logic kiểm tra và áp dụng theme
	const theme = (() => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
			return 'dark';
		}
		return 'light';
	})();

	if (theme === 'dark') {
		document.documentElement.setAttribute('data-theme', 'dark');
	}

	window.localStorage.setItem('theme', theme);

	const handleToggleClick = () => {
		const element = document.documentElement;
		const isDark = element.getAttribute('data-theme') === 'dark';
		const newTheme = isDark ? 'light' : 'dark';
		
		if (newTheme === 'dark') {
			element.setAttribute('data-theme', 'dark');
		} else {
			element.removeAttribute('data-theme');
		}
		
		localStorage.setItem('theme', newTheme);
	};

	document.getElementById('themeToggle').addEventListener('click', handleToggleClick);

	// Mobile hamburger menu toggle
	const menuToggle = document.getElementById('menuToggle');
	const navLinks = document.getElementById('navLinks');
	if (menuToggle && navLinks) {
		menuToggle.addEventListener('click', () => {
			navLinks.classList.toggle('nav-open');
			menuToggle.classList.toggle('is-active');
		});
		// Close menu when clicking a link
		navLinks.querySelectorAll('a').forEach(link => {
			link.addEventListener('click', () => {
				navLinks.classList.remove('nav-open');
				menuToggle.classList.remove('is-active');
			});
		});
	}

	// Hero banner transparent header
	document.addEventListener('DOMContentLoaded', () => {
		const heroBanner = document.querySelector('.hero-banner');
		const header = document.querySelector('.apple-header');
		if (heroBanner && header) {
			header.classList.add('hero-transparent');
			const onScroll = () => {
				if (window.scrollY > (heroBanner.clientHeight - 80)) {
					header.classList.remove('hero-transparent');
				} else {
					header.classList.add('hero-transparent');
				}
			};
			window.addEventListener('scroll', onScroll, { passive: true });
			onScroll();
		}
	});
</script>

<style>
	/* --- LAYOUT HEADER --- */
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(12px) saturate(180%);
		-webkit-backdrop-filter: blur(12px) saturate(180%);
		position: sticky;
		top: 0;
		z-index: 1000;
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		transition: background 0.5s cubic-bezier(0.16, 1, 0.3, 1),
		            border-color 0.5s cubic-bezier(0.16, 1, 0.3, 1),
		            backdrop-filter 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	/* Khi ở chế độ Dark Mode */
	:global([data-theme='dark']) header {
		background: rgba(15, 23, 42, 0.8);
		border-bottom-color: rgba(255, 255, 255, 0.1);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		height: 64px;
	}

	.logo a {
		font-family: var(--font-main);
		font-weight: 800;
		font-size: 1.2rem;
		color: #1e293b;
		text-decoration: none;
	}

	:global([data-theme='dark']) .logo a { color: #f1f5f9; }

	.internal-links { display: flex; gap: 5px; }

	.internal-links a {
		padding: 8px 16px;
		color: #64748b;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		border-radius: 20px;
		transition: all 0.3s ease;
	}

	.internal-links a:hover, .internal-links a.active {
		color: #0284c7;
		background: rgba(2, 132, 199, 0.08);
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	/* --- NÚT CHUYỂN THEME --- */
	.theme-btn {
		background: rgba(0, 0, 0, 0.05);
		border: none;
		border-radius: 10px;
		width: 38px;
		height: 38px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: 0.3s;
		font-size: 1.1rem;
	}

	.theme-btn:hover {
		background: rgba(0, 0, 0, 0.1);
		transform: scale(1.1);
	}

	.moon { display: none; }

	/* Hiển thị icon tương ứng theme */
	:global([data-theme='dark']) .sun { display: none; }
	:global([data-theme='dark']) .moon { display: block; }
	:global([data-theme='dark']) .theme-btn { background: rgba(255, 255, 255, 0.1); }

	/* Icon GitHub */
	.glass-icon-nav {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		border-radius: 10px;
		background: rgba(0, 0, 0, 0.03);
		color: #475569;
		transition: all 0.3s ease;
	}

	:global([data-theme='dark']) .glass-icon-nav {
		background: rgba(255, 255, 255, 0.1);
		color: #cbd5e1;
	}

	/* --- HAMBURGER MENU BUTTON --- */
	.menu-btn {
		display: none;
		background: rgba(0, 0, 0, 0.05);
		border: none;
		border-radius: 10px;
		width: 38px;
		height: 38px;
		cursor: pointer;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 5px;
		padding: 9px;
		transition: 0.3s;
	}

	:global([data-theme='dark']) .menu-btn {
		background: rgba(255, 255, 255, 0.1);
	}

	.hamburger-line {
		display: block;
		width: 18px;
		height: 2px;
		background: #475569;
		border-radius: 2px;
		transition: all 0.3s ease;
	}

	:global([data-theme='dark']) .hamburger-line {
		background: #cbd5e1;
	}

	/* Hamburger -> X animation */
	.menu-btn.is-active .hamburger-line:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.menu-btn.is-active .hamburger-line:nth-child(2) {
		opacity: 0;
	}
	.menu-btn.is-active .hamburger-line:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	@media (max-width: 720px) {
		.social-links { gap: 8px; }
		.logo a { font-size: 1rem; }

		/* Ẩn hamburger button trên desktop, hiện trên mobile */
		.menu-btn {
			display: flex;
		}

		/* Mobile nav dropdown */
		.internal-links {
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			z-index: 999;
			flex-direction: column;
			background: rgba(255, 255, 255, 0.98);
			backdrop-filter: blur(20px) saturate(180%);
			-webkit-backdrop-filter: blur(20px) saturate(180%);
			border-bottom: 1px solid rgba(0, 0, 0, 0.08);
			box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
			padding: 0.5rem 1rem 1rem;
			gap: 0;
			max-height: 0;
			overflow: hidden;
			opacity: 0;
			transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1),
			            opacity 0.3s ease,
			            padding 0.3s ease;
			pointer-events: none;
		}

		:global([data-theme='dark']) .internal-links {
			background: rgba(15, 23, 42, 0.95);
			border-bottom-color: rgba(255, 255, 255, 0.08);
		}

		.internal-links.nav-open {
			max-height: 320px;
			opacity: 1;
			padding: 0.5rem 1rem 1rem;
			pointer-events: auto;
		}

		.internal-links a {
			padding: 12px 16px;
			font-size: 0.95rem;
			white-space: nowrap;
			border-radius: 12px;
			width: 100%;
			text-align: left;
		}

		.internal-links a:hover, .internal-links a.active {
			background: rgba(2, 132, 199, 0.08);
		}
	}

	/* ===== TRANSPARENT HERO MODE ===== */
	:global(header.hero-transparent) {
		background: transparent !important;
		backdrop-filter: none !important;
		-webkit-backdrop-filter: none !important;
		border-bottom-color: transparent !important;
		position: fixed !important;
		width: 100%;
		top: 0;
		left: 0;
	}

	:global(header.hero-transparent) .logo a,
	:global(header.hero-transparent) .internal-links a {
		color: rgba(255,255,255,0.85) !important;
	}

	:global(header.hero-transparent) .internal-links a:hover,
	:global(header.hero-transparent) .internal-links a.active {
		color: #fff !important;
		background: rgba(255,255,255,0.12) !important;
	}

	:global(header.hero-transparent) .glass-icon-nav {
		color: rgba(255,255,255,0.85) !important;
		background: rgba(255,255,255,0.08) !important;
	}

	:global(header.hero-transparent) .theme-btn {
		background: rgba(255,255,255,0.08) !important;
	}
</style>