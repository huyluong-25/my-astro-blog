---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Admin - Manage Comments" description="Admin panel for moderating blog comments" />
		<style>
			main {
				width: 100%;
				max-width: 1000px;
				margin: auto;
				padding: 40px 20px;
			}

			.admin-header {
				margin-bottom: 40px;
				padding-bottom: 20px;
				border-bottom: 2px solid #e2e8f0;
			}

			[data-theme='dark'] .admin-header {
				border-bottom-color: #334155;
			}

			h1 {
				color: #0f172a;
				font-size: 2rem;
				margin: 0 0 10px 0;
				transition: color 0.3s;
			}

			[data-theme='dark'] h1 {
				color: #f1f5f9;
			}

			.admin-info {
				color: #64748b;
				font-size: 0.95rem;
				transition: color 0.3s;
			}

			[data-theme='dark'] .admin-info {
				color: #cbd5e1;
			}

			.auth-section {
				background: #f8fafc;
				border: 1px solid #e2e8f0;
				border-radius: 12px;
				padding: 25px;
				margin-bottom: 40px;
				transition: all 0.3s;
			}

			[data-theme='dark'] .auth-section {
				background: rgba(30, 41, 59, 0.5);
				border-color: #334155;
			}

			.auth-section h2 {
				color: #0f172a;
				margin-top: 0;
				transition: color 0.3s;
			}

			[data-theme='dark'] .auth-section h2 {
				color: #f1f5f9;
			}

			.form-group {
				margin-bottom: 15px;
			}

			label {
				display: block;
				margin-bottom: 8px;
				color: #334155;
				font-weight: 500;
				transition: color 0.3s;
			}

			[data-theme='dark'] label {
				color: #cbd5e1;
			}

			input[type="password"],
			select {
				width: 100%;
				padding: 10px 12px;
				border: 1px solid #e2e8f0;
				border-radius: 8px;
				font-size: 0.95rem;
				color: #334155;
				background: white;
				transition: all 0.3s;
				box-sizing: border-box;
			}

			[data-theme='dark'] input[type="password"],
			[data-theme='dark'] select {
				background: #1e293b;
				border-color: #475569;
				color: #cbd5e1;
			}

			input[type="password"]:focus,
			select:focus {
				outline: none;
				border-color: #0284c7;
				box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.1);
			}

			[data-theme='dark'] input[type="password"]:focus,
			[data-theme='dark'] select:focus {
				border-color: #38bdf8;
				box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.1);
			}

			.btn {
				padding: 10px 24px;
				background: #0284c7;
				color: white;
				border: none;
				border-radius: 8px;
				font-weight: 600;
				cursor: pointer;
				transition: all 0.3s;
			}

			.btn:hover {
				background: #0369a1;
				transform: translateY(-2px);
				box-shadow: 0 10px 25px rgba(2, 132, 199, 0.3);
			}

			[data-theme='dark'] .btn {
				background: #38bdf8;
				color: #0f172a;
			}

			[data-theme='dark'] .btn:hover {
				background: #0284c7;
			}

			.comments-section {
				display: none;
			}

			.comments-section.authenticated {
				display: block;
			}

			.comments-list {
				display: flex;
				flex-direction: column;
				gap: 20px;
			}

			.comment-item {
				background: #f8fafc;
				border: 1px solid #e2e8f0;
				border-radius: 12px;
				padding: 20px;
				transition: all 0.3s;
			}

			[data-theme='dark'] .comment-item {
				background: rgba(30, 41, 59, 0.5);
				border-color: #334155;
			}

			.comment-header {
				display: flex;
				justify-content: space-between;
				align-items: start;
				margin-bottom: 12px;
				gap: 15px;
			}

			.comment-author {
				font-weight: 600;
				color: #0f172a;
				transition: color 0.3s;
			}

			[data-theme='dark'] .comment-author {
				color: #f1f5f9;
			}

			.comment-meta {
				font-size: 0.85rem;
				color: #64748b;
				transition: color 0.3s;
			}

			[data-theme='dark'] .comment-meta {
				color: #94a3b8;
			}

			.comment-slug {
				display: inline-block;
				background: #dbeafe;
				color: #0284c7;
				padding: 4px 10px;
				border-radius: 6px;
				font-size: 0.8rem;
				font-weight: 600;
				margin-right: 8px;
				transition: all 0.3s;
			}

			[data-theme='dark'] .comment-slug {
				background: rgba(56, 189, 248, 0.2);
				color: #38bdf8;
			}

			.comment-content {
				color: #334155;
				line-height: 1.6;
				margin-bottom: 15px;
				word-break: break-word;
				transition: color 0.3s;
			}

			[data-theme='dark'] .comment-content {
				color: #cbd5e1;
			}

			.comment-actions {
				display: flex;
				gap: 10px;
				flex-wrap: wrap;
			}

			.btn-approve {
				background: #22c55e;
				padding: 8px 16px;
				font-size: 0.9rem;
			}

			.btn-approve:hover {
				background: #16a34a;
				box-shadow: 0 10px 25px rgba(34, 197, 94, 0.3);
			}

			[data-theme='dark'] .btn-approve {
				background: #22c55e;
			}

			[data-theme='dark'] .btn-approve:hover {
				background: #16a34a;
			}

			.btn-reject {
				background: #ef4444;
				padding: 8px 16px;
				font-size: 0.9rem;
			}

			.btn-reject:hover {
				background: #dc2626;
				box-shadow: 0 10px 25px rgba(239, 68, 68, 0.3);
			}

			[data-theme='dark'] .btn-reject {
				background: #ef4444;
			}

			[data-theme='dark'] .btn-reject:hover {
				background: #dc2626;
			}

			.status-badge {
				display: inline-block;
				padding: 4px 12px;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 600;
			}

			.status-pending {
				background: #fef08a;
				color: #78350f;
			}

			.status-approved {
				background: #d1fae5;
				color: #065f46;
			}

			.status-rejected {
				background: #fee2e2;
				color: #7f1d1d;
			}

			[data-theme='dark'] .status-pending {
				background: rgba(253, 230, 138, 0.2);
				color: #fbbf24;
			}

			[data-theme='dark'] .status-approved {
				background: rgba(167, 243, 208, 0.2);
				color: #6ee7b7;
			}

			[data-theme='dark'] .status-rejected {
				background: rgba(254, 226, 226, 0.2);
				color: #fca5a5;
			}

			.empty-state {
				text-align: center;
				padding: 40px;
				color: #64748b;
			}

			[data-theme='dark'] .empty-state {
				color: #94a3b8;
			}

			.message {
				padding: 12px 15px;
				border-radius: 8px;
				margin-bottom: 15px;
				transition: all 0.3s;
			}

			.message.success {
				background: #dcfce7;
				border: 1px solid #bbf7d0;
				color: #166534;
			}

			[data-theme='dark'] .message.success {
				background: rgba(34, 197, 94, 0.1);
				border-color: rgba(34, 197, 94, 0.3);
				color: #86efac;
			}

			.message.error {
				background: #fee2e2;
				border: 1px solid #fecaca;
				color: #dc2626;
			}

			[data-theme='dark'] .message.error {
				background: rgba(220, 38, 38, 0.1);
				border-color: rgba(220, 38, 38, 0.3);
				color: #fca5a5;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="admin-header">
				<h1>🔐 Comments Admin Panel</h1>
				<p class="admin-info">Moderate and manage blog comments</p>
			</div>

			<div id="messageContainer"></div>

			<div class="auth-section">
				<h2>Authentication</h2>
				<div class="form-group">
					<label for="password">Admin Password:</label>
					<input 
						type="password" 
						id="password" 
						placeholder="Enter admin password"
					/>
				</div>
				<div class="form-group">
					<label for="statusFilter">Filter by Status:</label>
					<select id="statusFilter">
						<option value="pending">Pending (Need Review)</option>
						<option value="approved">Approved</option>
						<option value="rejected">Rejected</option>
					</select>
				</div>
				<button class="btn" id="loginBtn">Load Comments</button>
			</div>

			<div class="comments-section" id="commentsSection">
				<h2 style="color: #0f172a; transition: color 0.3s;">Comments</h2>
				<div id="commentsList" class="comments-list"></div>
			</div>
		</main>
		<Footer />

		<script>
			const loginBtn = document.getElementById('loginBtn');
			const passwordInput = document.getElementById('password');
			const statusFilter = document.getElementById('statusFilter');
			const commentsSection = document.getElementById('commentsSection');
			const commentsList = document.getElementById('commentsList');
			const messageContainer = document.getElementById('messageContainer');

			function showMessage(text, type = 'success') {
				const msg = document.createElement('div');
				msg.className = `message ${type}`;
				msg.textContent = text;
				messageContainer.innerHTML = '';
				messageContainer.appendChild(msg);
				setTimeout(() => msg.remove(), 3000);
			}

			function escapeHtml(text) {
				const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
				return text.replace(/[&<>"']/g, m => map[m]);
			}

			async function loadComments() {
				const password = passwordInput.value;
				const status = statusFilter.value;

				if (!password) {
					showMessage('Please enter password', 'error');
					return;
				}

				try {
					const res = await fetch(`/api/admin/comments?status=${status}`, {
						headers: {
							'Authorization': `Bearer ${password}`
						}
					});

					if (res.status === 401) {
						showMessage('Invalid password', 'error');
						return;
					}

					if (!res.ok) throw new Error('Failed to load comments');

					const comments = await res.json();
					commentsSection.classList.add('authenticated');

					if (comments.length === 0) {
						commentsList.innerHTML = '<div class="empty-state">No comments in this category</div>';
						return;
					}

					commentsList.innerHTML = comments.map(comment => `
						<div class="comment-item" data-id="${comment.id}">
							<div class="comment-header">
								<div>
									<div>
										<span class="comment-slug">${escapeHtml(comment.slug)}</span>
										<span class="status-badge status-${comment.status}">${comment.status.toUpperCase()}</span>
									</div>
									<div class="comment-author">${escapeHtml(comment.author)}</div>
									<div class="comment-meta">${escapeHtml(comment.email)} • ${new Date(comment.created_at).toLocaleString()}</div>
								</div>
							</div>
							<p class="comment-content">${escapeHtml(comment.content)}</p>
							<div class="comment-actions">
								<button class="btn btn-approve" onclick="approveComment(${comment.id})">✓ Approve</button>
								<button class="btn btn-reject" onclick="rejectComment(${comment.id})">✗ Reject</button>
							</div>
						</div>
					`).join('');
				} catch (error) {
					showMessage('Error: ' + error.message, 'error');
				}
			}

			window.approveComment = async (id) => {
				const password = passwordInput.value;
				try {
					const res = await fetch('/api/admin/comments', {
						method: 'PATCH',
						headers: {
							'Authorization': `Bearer ${password}`,
							'Content-Type': 'application/json'
						},
						body: JSON.stringify({ id, status: 'approved' })
					});

					if (res.ok) {
						showMessage('✓ Comment approved');
						document.querySelector(`[data-id="${id}"]`).remove();
					} else {
						showMessage('Failed to approve', 'error');
					}
				} catch (error) {
					showMessage('Error: ' + error.message, 'error');
				}
			};

			window.rejectComment = async (id) => {
				const password = passwordInput.value;
				try {
					const res = await fetch('/api/admin/comments', {
						method: 'PATCH',
						headers: {
							'Authorization': `Bearer ${password}`,
							'Content-Type': 'application/json'
						},
						body: JSON.stringify({ id, status: 'rejected' })
					});

					if (res.ok) {
						showMessage('✓ Comment rejected');
						document.querySelector(`[data-id="${id}"]`).remove();
					} else {
						showMessage('Failed to reject', 'error');
					}
				} catch (error) {
					showMessage('Error: ' + error.message, 'error');
				}
			};

			loginBtn.addEventListener('click', loadComments);
			passwordInput.addEventListener('keypress', (e) => {
				if (e.key === 'Enter') loadComments();
			});

			statusFilter.addEventListener('change', () => {
				if (commentsSection.classList.contains('authenticated')) {
					loadComments();
				}
			});
		</script>
	</body>
</html>
