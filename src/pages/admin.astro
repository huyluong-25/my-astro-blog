---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Admin" description="Backend migration in progress" />
    <style>
      main {
        width: min(900px, 92%);
        margin: 0 auto;
        padding: 48px 0 72px;
      }

      .notice {
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        border-radius: 12px;
        padding: 24px;
        color: #0f172a;
      }

      .notice h1 {
        margin: 0 0 12px;
        font-size: 1.6rem;
      }

      .notice p {
        margin: 8px 0;
        color: #334155;
      }

      [data-theme='dark'] .notice {
        border-color: #334155;
        background: rgba(30, 41, 59, 0.5);
        color: #f1f5f9;
      }

      [data-theme='dark'] .notice p {
        color: #cbd5e1;
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <section class="notice">
        <h1>Admin Panel Unavailable</h1>
        <p>Cloudflare comment database and moderation APIs were removed.</p>
        <p>Connect your new backend, then update this page to manage comments.</p>
      </section>
    </main>
    <Footer />
  </body>
</html>
