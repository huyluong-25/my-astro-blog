---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const notes = (await getCollection('toeic')).sort((a, b) => {
  const ao = a.data.order ?? 999;
  const bo = b.data.order ?? 999;
  if (ao !== bo) return ao - bo;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});
---

<!doctype html>
<html lang="vi">
  <head>
    <BaseHead title="Thư Viện Ngữ Pháp TOEIC" description="Kho bài học TOEIC theo từng chủ đề và từng thì." />
    <style>
      main {
        width: 960px;
      }

      /* Hero section */
      .hero {
        margin-bottom: 1.5rem;
        background: linear-gradient(120deg, rgba(2, 132, 199, 0.1), rgba(56, 189, 248, 0.08));
        border: 1px solid rgba(2, 132, 199, 0.18);
        border-radius: 18px;
        padding: 1.4rem 1.5rem;
        animation: fadeInUp 0.7s ease-out;
        position: relative;
        overflow: hidden;
      }

      .hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, rgba(2, 132, 199, 0.12) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
      }

      .hero h1 {
        margin: 0 0 0.4rem;
        font-size: clamp(1.4rem, 3vw, 1.9rem);
      }

      .hero p {
        margin: 0;
        color: #334155;
      }

      .stats-row {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
      }

      .stat-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 14px;
        background: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(2, 132, 199, 0.15);
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #0369a1;
        backdrop-filter: blur(4px);
      }

      /* Lesson list */
      ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 0.7rem;
      }

      li {
        animation: fadeInUp 0.6s ease-out backwards;
      }

      li a {
        display: grid;
        grid-template-columns: 48px 1fr;
        gap: 1rem;
        align-items: center;
        border: 1px solid #dbe5f0;
        border-radius: 14px;
        padding: 1rem;
        background: #fff;
        text-decoration: none;
        transition: all 0.35s cubic-bezier(0.165, 0.84, 0.44, 1);
      }

      li a:hover {
        transform: translateY(-4px) scale(1.005);
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        box-shadow:
          0 16px 32px rgba(0, 0, 0, 0.06),
          inset 0 0 0 1px rgba(255, 255, 255, 0.5);
        border-color: rgba(2, 132, 199, 0.2);
      }

      /* Lesson number badge */
      .lesson-num {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #0284c7, #38bdf8);
        border-radius: 12px;
        color: #fff;
        font-weight: 800;
        font-size: 1.1rem;
        flex-shrink: 0;
        transition: transform 0.3s;
      }

      li a:hover .lesson-num {
        transform: scale(1.1) rotate(-3deg);
      }

      .lesson-info {
        min-width: 0;
      }

      .title {
        margin: 0;
        color: #0f172a;
        font-size: 1.05rem;
        font-weight: 700;
        transition: color 0.3s;
      }

      .desc {
        margin: 0.25rem 0;
        color: #475569;
        font-size: 0.92rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        transition: color 0.3s;
      }

      .date {
        margin: 0;
        font-size: 0.82rem;
        color: #94a3b8;
        transition: color 0.3s;
      }

      /* Stagger animation delays */
      li:nth-child(1) { animation-delay: 0.05s; }
      li:nth-child(2) { animation-delay: 0.1s; }
      li:nth-child(3) { animation-delay: 0.15s; }
      li:nth-child(4) { animation-delay: 0.2s; }
      li:nth-child(5) { animation-delay: 0.25s; }
      li:nth-child(6) { animation-delay: 0.3s; }
      li:nth-child(7) { animation-delay: 0.35s; }
      li:nth-child(8) { animation-delay: 0.4s; }
      li:nth-child(9) { animation-delay: 0.45s; }
      li:nth-child(10) { animation-delay: 0.5s; }
      li:nth-child(11) { animation-delay: 0.55s; }
      li:nth-child(12) { animation-delay: 0.6s; }
      li:nth-child(13) { animation-delay: 0.65s; }

      /* Responsive */
      @media (max-width: 640px) {
        li a {
          grid-template-columns: 40px 1fr;
          gap: 0.75rem;
          padding: 0.8rem;
        }

        .lesson-num {
          width: 40px;
          height: 40px;
          font-size: 0.95rem;
          border-radius: 10px;
        }

        .title {
          font-size: 0.98rem;
        }

        .desc {
          font-size: 0.85rem;
        }

        li a:hover {
          transform: none;
          box-shadow: none;
        }
      }

      /* ======= DARK MODE ======= */
      [data-theme='dark'] .hero {
        background: linear-gradient(120deg, rgba(2, 132, 199, 0.2), rgba(56, 189, 248, 0.12));
        border-color: rgba(56, 189, 248, 0.35);
      }

      [data-theme='dark'] .hero p {
        color: #cbd5e1;
      }

      [data-theme='dark'] .stat-chip {
        background: rgba(15, 23, 42, 0.6);
        border-color: rgba(56, 189, 248, 0.2);
        color: #7dd3fc;
      }

      [data-theme='dark'] li a {
        background: rgba(15, 23, 42, 0.92);
        border-color: #334155;
      }

      [data-theme='dark'] li a:hover {
        background: rgba(30, 41, 59, 0.95);
        border-color: rgba(56, 189, 248, 0.25);
        box-shadow:
          0 16px 32px rgba(0, 0, 0, 0.3),
          inset 0 0 0 1px rgba(255, 255, 255, 0.05);
      }

      [data-theme='dark'] .title {
        color: #f1f5f9;
      }

      [data-theme='dark'] .desc {
        color: #94a3b8;
      }

      [data-theme='dark'] .date {
        color: #64748b;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>Thư Viện Ngữ Pháp TOEIC</h1>
        <p>
          Chọn một bài học để ôn tập nhanh. Mỗi bài là một trang riêng để bạn đọc lại và chỉnh sửa nội dung dễ dàng.
        </p>
        <div class="stats-row">
          <span class="stat-chip">📚 {notes.length} bài học</span>
          <span class="stat-chip">🎯 TOEIC Grammar</span>
        </div>
      </section>

      <ul>
        {
          notes.map((note, index) => (
            <li>
              <a href={`/toeic/${note.id}/`} data-astro-prefetch="hover">
                <span class="lesson-num">{index + 1}</span>
                <div class="lesson-info">
                  <h3 class="title">{note.data.title}</h3>
                  <p class="desc">{note.data.description}</p>
                  <p class="date">
                    <FormattedDate date={note.data.pubDate} />
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>
