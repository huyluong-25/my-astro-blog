---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const notes = (await getCollection('toeic')).sort((a, b) => {
  const ao = a.data.order ?? 999;
  const bo = b.data.order ?? 999;
  if (ao !== bo) return ao - bo;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const categoryConfig: Record<string, { label: string; icon: string; color: string; bg: string }> = {
  'foundation': { label: 'Nền Tảng Câu', icon: '🏗️', color: '#2563eb', bg: 'rgba(37, 99, 235, 0.08)' },
  'tenses': { label: 'Các Thì Tiếng Anh', icon: '⏰', color: '#059669', bg: 'rgba(5, 150, 105, 0.08)' },
  'word-forms': { label: 'Từ Loại & Cụm Từ', icon: '🔤', color: '#7c3aed', bg: 'rgba(124, 58, 237, 0.08)' },
  'verb-patterns': { label: 'Cấu Trúc Động Từ', icon: '⚙️', color: '#ea580c', bg: 'rgba(234, 88, 12, 0.08)' },
  'listening': { label: 'Luyện Listening', icon: '🎧', color: '#e11d48', bg: 'rgba(225, 29, 72, 0.08)' },
};
---

<!doctype html>
<html lang="vi">
  <head>
    <BaseHead title="Lộ Trình Ngữ Pháp TOEIC Bứt Phá Điểm Số" description="Hệ thống bài học ngữ pháp TOEIC trực quan, phong cách E-Learning hiện đại." />
    <style>
      :root {
        --primary-gradient: linear-gradient(135deg, #0ea5e9 0%, #6366f1 100%);
        --card-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.05);
        --card-hover-shadow: 0 20px 40px -10px rgba(14, 165, 233, 0.15);
      }

      main {
        width: 100%;
        max-width: 1140px;
        margin: 0 auto;
        padding: 2rem 1.2rem 5rem;
      }

      /* Hero Premium Container */
      .hero-wrapper {
        position: relative;
        background: var(--primary-gradient);
        border-radius: 28px;
        padding: 3rem 2.5rem;
        color: #ffffff;
        overflow: hidden;
        margin-bottom: 2.5rem;
        box-shadow: 0 20px 40px -15px rgba(99, 102, 241, 0.4);
      }

      .hero-wrapper::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        margin-bottom: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.3);
      }

      .hero-title {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 900;
        margin: 0 0 1rem;
        line-height: 1.2;
        letter-spacing: -0.02em;
      }

      .hero-subtitle {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.9);
        margin: 0 0 2rem;
        max-width: 680px;
        line-height: 1.6;
      }

      .hero-metrics {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 1.2rem;
        background: rgba(0, 0, 0, 0.15);
        backdrop-filter: blur(12px);
        padding: 1.2rem 1.5rem;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.15);
      }

      .metric-item {
        display: flex;
        flex-direction: column;
      }

      .metric-value {
        font-size: 1.5rem;
        font-weight: 900;
      }

      .metric-label {
        font-size: 0.82rem;
        color: rgba(255, 255, 255, 0.8);
        font-weight: 600;
      }

      /* Tab Navigation Filter */
      .filter-nav {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        overflow-x: auto;
        padding: 0.5rem 0.2rem 1.5rem;
        margin-bottom: 1rem;
        scrollbar-width: none;
      }
      .filter-nav::-webkit-scrollbar { display: none; }

      .tab-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        border-radius: 50px;
        font-size: 0.92rem;
        font-weight: 700;
        color: #475569;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.25s ease;
      }

      .tab-btn:hover, .tab-btn.active {
        background: #0f172a;
        color: #ffffff;
        border-color: #0f172a;
        box-shadow: 0 8px 20px -4px rgba(15, 23, 42, 0.3);
      }

      /* Course Cards Grid */
      .course-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
        gap: 1.5rem;
      }

      .course-card {
        background: #ffffff;
        border: 1.5px solid #f1f5f9;
        border-radius: 24px;
        padding: 1.6rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        text-decoration: none;
        position: relative;
        transition: all 0.35s cubic-bezier(0.165, 0.84, 0.44, 1);
        box-shadow: var(--card-shadow);
      }

      .course-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--card-hover-shadow);
        border-color: rgba(14, 165, 233, 0.4);
      }

      .card-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.2rem;
      }

      .cat-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: 30px;
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }

      .lesson-number-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #f1f5f9;
        color: #0f172a;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 0.9rem;
      }

      .course-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 0.6rem;
        line-height: 1.4;
      }

      .course-desc {
        font-size: 0.9rem;
        color: #64748b;
        margin: 0 0 1.5rem;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .card-bottom-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1rem;
        border-top: 1px solid #f1f5f9;
      }

      .start-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.88rem;
        font-weight: 800;
        color: #0ea5e9;
        transition: gap 0.2s;
      }

      .course-card:hover .start-btn {
        gap: 10px;
      }

      /* Mobile Layout */
      @media (max-width: 640px) {
        main { padding: 1.2rem 0.8rem 3rem; }
        .hero-wrapper { padding: 2rem 1.4rem; border-radius: 20px; }
        .hero-metrics { grid-template-columns: 1fr 1fr; }
        .course-grid { grid-template-columns: 1fr; gap: 1.2rem; }
      }

      /* Dark Theme */
      [data-theme='dark'] .tab-btn {
        background: #1e293b;
        border-color: #334155;
        color: #cbd5e1;
      }
      [data-theme='dark'] .tab-btn:hover, [data-theme='dark'] .tab-btn.active {
        background: #38bdf8;
        color: #0f172a;
        border-color: #38bdf8;
      }
      [data-theme='dark'] .course-card {
        background: #0f172a;
        border-color: #1e293b;
        box-shadow: none;
      }
      [data-theme='dark'] .course-card:hover {
        background: #1e293b;
        border-color: #38bdf8;
      }
      [data-theme='dark'] .course-title { color: #f8fafc; }
      [data-theme='dark'] .course-desc { color: #94a3b8; }
      [data-theme='dark'] .card-bottom-bar { border-top-color: #1e293b; }
      [data-theme='dark'] .lesson-number-circle { background: #1e293b; color: #f8fafc; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <!-- Hero Section -->
      <section class="hero-wrapper">
        <div class="hero-badge">🚀 Trọn Bộ Kỹ Năng TOEIC 2026</div>
        <h1 class="hero-title">Lộ Trình Ngữ Pháp TOEIC Thực Chiến</h1>
        <p class="hero-subtitle">
          Tổng hợp toàn bộ cấu trúc trọng tâm, bẫy đề thi Part 5 & 6 cùng chiến thuật xử lý câu hỏi nhanh gọn giúp bạn tối ưu hóa điểm số.
        </p>
        <div class="hero-metrics">
          <div class="metric-item">
            <span class="metric-value">{notes.length} Bài</span>
            <span class="metric-label">Lộ trình chuẩn hoá</span>
          </div>
          <div class="metric-item">
            <span class="metric-value">5 Nhóm</span>
            <span class="metric-label">Chủ đề phân loại</span>
          </div>
          <div class="metric-item">
            <span class="metric-value">100%</span>
            <span class="metric-label">Giải thích chi tiết</span>
          </div>
        </div>
      </section>

      <!-- Category Tabs Filter -->
      <div class="filter-nav">
        <button class="tab-btn active" onclick="filterCategory('all', this)">✨ Tất Cả ({notes.length})</button>
        {Object.entries(categoryConfig).map(([key, cfg]) => {
          const count = notes.filter(n => (n.data.category || 'foundation') === key).length;
          if (count === 0) return null;
          return (
            <button class="tab-btn" onclick={`filterCategory('${key}', this)`}>
              <span>{cfg.icon}</span>
              <span>{cfg.label} ({count})</span>
            </button>
          );
        })}
      </div>

      <!-- Course Cards Container -->
      <div class="course-grid" id="course-container">
        {notes.map((note, idx) => {
          const catKey = note.data.category || 'foundation';
          const cfg = categoryConfig[catKey] || categoryConfig['foundation'];
          
          return (
            <a 
              href={`/toeic/${note.id}/`} 
              class="course-card" 
              data-category={catKey}
            >
              <div>
                <div class="card-header-row">
                  <span class="cat-tag" style={`background: ${cfg.bg}; color: ${cfg.color};`}>
                    {cfg.icon} {cfg.label}
                  </span>
                  <span class="lesson-number-circle">
                    #{note.data.order ?? idx + 1}
                  </span>
                </div>
                
                <h3 class="course-title">{note.data.title}</h3>
                <p class="course-desc">{note.data.description}</p>
              </div>

              <div class="card-bottom-bar">
                <span style="font-size: 0.8rem; color: #94a3b8; font-weight: 600;">Part 5 & 6 Focus</span>
                <span class="start-btn" style={`color: ${cfg.color};`}>
                  Học bài này ➔
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </main>
    <Footer />

    <script is:inline>
      function filterCategory(cat, btn) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const cards = document.querySelectorAll('.course-card');
        cards.forEach(card => {
          if (cat === 'all' || card.getAttribute('data-category') === cat) {
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
          }
        });
      }
    </script>
  </body>
</html>
