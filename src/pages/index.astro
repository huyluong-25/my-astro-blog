---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="liquid-bg">
			<div class="blob blob-1"></div>
			<div class="blob blob-2"></div>
		</div>

		<main>
			<section class="hero-section">
				<div class="hero-content">
					<div class="greeting">
						<span class="hello">👋</span>
						<span class="text">Hello, I'm</span>
					</div>

					<h1><span id="typed"></span></h1>

					<p class="tagline">Building reliable systems & passionate about badminton</p>

					<div class="divider"></div>

					<article class="intro-section">
						<p>I'm an <strong>IT Support specialist</strong> at TiniGroup, focused on system optimization and automation. When I'm not troubleshooting servers, you'll find me on the badminton court or exploring new technologies.</p>
						
						<div class="cta-group">
							<a href="/blog" class="btn btn-primary">Read My Blog →</a>
							<a href="/about" class="btn btn-secondary">About Me</a>
						</div>
					</article>
				</div>

				<div class="accent-shape"></div>
			</section>
		</main>
		<Footer />

		<script>
			import Typed from 'typed.js';

			new Typed('#typed', {
				strings: ['Huy.', 'an Engineer.', 'a Problem Solver.'],
				typeSpeed: 60,
				backSpeed: 40,
				loop: true,
				cursorChar: '▌'
			});
		</script>
	</body>
</html>

<style>
	/* Background setup - Minimalist */
	.liquid-bg {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
		overflow: hidden;
		transition: background 0.3s ease;
	}

	[data-theme='dark'] .liquid-bg {
		background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
	}

	/* Subtle animated blobs */
	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(60px);
		opacity: 0.15;
		animation: drift 20s infinite alternate ease-in-out;
		transition: opacity 0.3s ease;
	}

	.blob-1 {
		width: 400px;
		height: 400px;
		background: #0284c7;
		top: -10%;
		left: -5%;
		animation-duration: 25s;
	}

	.blob-2 {
		width: 350px;
		height: 350px;
		background: #38bdf8;
		bottom: -10%;
		right: -5%;
		animation-duration: 30s;
		animation-delay: -5s;
	}

	[data-theme='dark'] .blob {
		opacity: 0.08;
	}

	@keyframes drift {
		from {
			transform: translate(0, 0) scale(1);
		}
		to {
			transform: translate(50px, 50px) scale(1.1);
		}
	}

	/* Main content */
	main {
		width: 100%;
		max-width: 700px;
		margin: auto;
		padding: 80px 30px;
		position: relative;
		z-index: 1;
	}

	.hero-section {
		animation: fadeIn 0.8s ease-out;
		position: relative;
	}

	.hero-content {
		text-align: center;
		position: relative;
		z-index: 2;
	}

	/* Greeting */
	.greeting {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		margin-bottom: 20px;
		animation: slideDown 0.6s ease-out;
	}

	.greeting .hello {
		font-size: 2rem;
		animation: wave 2s ease-in-out infinite;
		display: inline-block;
		transform-origin: 70% 70%;
	}

	.greeting .text {
		font-size: 0.95rem;
		color: #64748b;
		text-transform: uppercase;
		letter-spacing: 1.5px;
		font-weight: 500;
		transition: color 0.3s ease;
	}

	[data-theme='dark'] .greeting .text {
		color: #94a3b8;
	}

	@keyframes wave {
		0%, 100% { transform: rotate(0deg); }
		25% { transform: rotate(20deg); }
	}

	@keyframes slideDown {
		from {
			opacity: 0;
			transform: translateY(-20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Main heading */
	h1 {
		font-size: 3.5rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 20px 0;
		line-height: 1.1;
		transition: color 0.3s ease;
		animation: fadeInUp 0.8s ease-out 0.1s backwards;
		background: linear-gradient(135deg, #0f172a 0%, #0284c7 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	[data-theme='dark'] h1 {
		background: linear-gradient(135deg, #f1f5f9 0%, #38bdf8 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	/* Tagline */
	.tagline {
		font-size: 1.15rem;
		color: #64748b;
		margin: 0 0 40px 0;
		letter-spacing: 0.3px;
		transition: color 0.3s ease;
		animation: fadeInUp 0.8s ease-out 0.2s backwards;
	}

	[data-theme='dark'] .tagline {
		color: #cbd5e1;
	}

	/* Divider */
	.divider {
		width: 60px;
		height: 3px;
		background: linear-gradient(90deg, #0284c7, #38bdf8);
		border-radius: 2px;
		margin: 40px auto;
		animation: expandWidth 0.8s ease-out 0.3s backwards;
	}

	@keyframes expandWidth {
		from {
			width: 0;
			opacity: 0;
		}
		to {
			width: 60px;
			opacity: 1;
		}
	}

	/* Intro section */
	.intro-section {
		animation: fadeInUp 0.8s ease-out 0.3s backwards;
	}

	.intro-section p {
		font-size: 1.05rem;
		line-height: 1.8;
		color: #334155;
		margin-bottom: 30px;
		transition: color 0.3s ease;
	}

	[data-theme='dark'] .intro-section p {
		color: #cbd5e1;
	}

	.intro-section strong {
		color: #0284c7;
		font-weight: 600;
		transition: color 0.3s ease;
	}

	[data-theme='dark'] .intro-section strong {
		color: #38bdf8;
	}

	/* CTA Buttons */
	.cta-group {
		display: flex;
		gap: 15px;
		justify-content: center;
		flex-wrap: wrap;
		animation: fadeInUp 0.8s ease-out 0.4s backwards;
	}

	.btn {
		padding: 13px 32px;
		border-radius: 8px;
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
		border: 2px solid transparent;
		cursor: pointer;
		display: inline-block;
		position: relative;
		overflow: hidden;
		letter-spacing: 0.3px;
	}

	.btn::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
		transition: left 0.6s ease;
		z-index: -1;
	}

	.btn:hover::before {
		left: 100%;
	}

	/* Primary Button */
	.btn-primary {
		background: #0284c7;
		color: white;
	}

	.btn-primary:hover {
		background: #0369a1;
		transform: translateY(-2px);
		box-shadow: 0 10px 25px rgba(2, 132, 199, 0.3);
	}

	[data-theme='dark'] .btn-primary {
		background: #38bdf8;
		color: #0f172a;
	}

	[data-theme='dark'] .btn-primary:hover {
		background: #0284c7;
		box-shadow: 0 10px 25px rgba(56, 189, 248, 0.3);
	}

	/* Secondary Button */
	.btn-secondary {
		background: transparent;
		color: #0284c7;
		border: 2px solid #0284c7;
	}

	.btn-secondary:hover {
		background: #0284c7;
		color: white;
		transform: translateY(-2px);
		box-shadow: 0 10px 25px rgba(2, 132, 199, 0.2);
	}

	[data-theme='dark'] .btn-secondary {
		color: #38bdf8;
		border-color: #38bdf8;
	}

	[data-theme='dark'] .btn-secondary:hover {
		background: #38bdf8;
		color: #0f172a;
		box-shadow: 0 10px 25px rgba(56, 189, 248, 0.2);
	}

	/* Accent shape */
	.accent-shape {
		position: absolute;
		width: 300px;
		height: 300px;
		background: radial-gradient(circle, rgba(2, 132, 199, 0.1) 0%, transparent 70%);
		border-radius: 50%;
		bottom: -150px;
		right: -100px;
		pointer-events: none;
		z-index: 0;
	}

	[data-theme='dark'] .accent-shape {
		background: radial-gradient(circle, rgba(56, 189, 248, 0.08) 0%, transparent 70%);
	}

	/* General animations */
	@keyframes fadeIn {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Mobile responsive */
	@media (max-width: 640px) {
		main {
			padding: 60px 20px;
		}

		h1 {
			font-size: 2.5rem;
		}

		.tagline {
			font-size: 1rem;
		}

		.intro-section p {
			font-size: 1rem;
		}

		.cta-group {
			gap: 10px;
		}

		.btn {
			padding: 12px 28px;
			font-size: 0.9rem;
		}

		.greeting .hello {
			font-size: 1.5rem;
		}

		.greeting .text {
			font-size: 0.85rem;
		}
	}

	/* Extra polish for very small phones */
	@media (max-width: 420px) {
		main {
			padding: 52px 16px;
		}

		h1 {
			font-size: 2.1rem;
			line-height: 1.15;
		}

		.tagline {
			font-size: 0.95rem;
			margin-bottom: 30px;
		}

		.intro-section p {
			font-size: 0.96rem;
			line-height: 1.7;
		}

		.cta-group {
			width: 100%;
			gap: 12px;
		}

		.btn {
			width: 100%;
			padding: 12px 16px;
			text-align: center;
		}

		.divider {
			margin: 30px auto;
		}

		.blob {
			filter: blur(48px);
			opacity: 0.1;
		}

		.accent-shape {
			display: none;
		}
	}
</style>