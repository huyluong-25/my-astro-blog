---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="liquid-bg">
			<div class="blob blob-1"></div>
			<div class="blob blob-2"></div>
			<div class="blob blob-3"></div>
		</div>

		<main>
			<section class="hero-section">
				<div class="glass-card" data-tilt data-tilt-max="10" data-tilt-speed="1000" data-tilt-glare data-tilt-max-glare="0.2">
					<div class="card-content">
						<h1>Hi, I'm <span id="typed"></span></h1>
						<p class="subtitle">Trải nghiệm không gian của Huy</p>
						
						<div class="animation-zone">
							<div class="character-wrapper">
								<span id="main-icon" class="floating-icon">🏸</span>
							</div>
						</div>

						<div class="dot-container">
							<span class="dot"></span><span class="dot"></span><span class="dot"></span><span class="dot"></span>
						</div>
					</div>
				</div>

				<article class="intro-text">
					<p>Tối ưu <strong>Hệ thống</strong> & Cháy hết mình với <strong>Cầu lông</strong>.</p>
					<a href="/blog" class="cta-button">Xem Blog của mình →</a>
				</article>
			</section>
		</main>
		<Footer />

		<script>
			import Typed from 'typed.js';
			import VanillaTilt from 'vanilla-tilt';

			new Typed('#typed', {
				strings: ['Huy.', 'an Engineer.', 'a Minimalist.'],
				typeSpeed: 70, backSpeed: 50, loop: true, cursorChar: '_'
			});

			const card = document.querySelector(".glass-card");
			VanillaTilt.init(card as HTMLElement);

			const icons = ['🏸', '💻', '📸', '☕'];
			let iconIndex = 0;
			const mainIconEl = document.getElementById('main-icon');
			function cycleIcons() {
				if (!mainIconEl) return;
				mainIconEl.style.opacity = '0.5';
				setTimeout(() => {
					mainIconEl.innerText = icons[iconIndex];
					mainIconEl.style.opacity = '1';
					iconIndex = (iconIndex + 1) % icons.length;
				}, 150);
			}
			setInterval(cycleIcons, 800);
		</script>
	</body>
</html>

<style>
	/* NỀN LIQUID - APPLE STYLE */
	.liquid-bg {
		position: fixed;
		top: 0; left: 0; width: 100%; height: 100%;
		z-index: -1;
		background: #ffffff; /* Nền trắng tinh khôi */
		overflow: hidden;
	}

	.blob {
		position: absolute;
		width: 500px;
		height: 500px;
		filter: blur(80px); /* Làm nhòe cực mạnh để tạo hiệu ứng loang */
		border-radius: 50%;
		opacity: 0.4;
		animation: move 20s infinite alternate;
	}

	.blob-1 { background: #bae6fd; top: -10%; left: -10%; animation-duration: 25s; }
	.blob-2 { background: #fef08a; bottom: -10%; right: -10%; animation-duration: 30s; animation-delay: -5s; }
	.blob-3 { background: #fbcfe8; top: 40%; left: 30%; animation-duration: 20s; animation-delay: -2s; }

	@keyframes move {
		from { transform: translate(0, 0) scale(1); }
		to { transform: translate(100px, 100px) scale(1.2); }
	}

	main {
		width: 100%; max-width: 800px; margin: auto; padding: 60px 20px;
		perspective: 1000px;
	}

	/* CARD THỦY TINH LỎNG (LIQUID GLASS) */
	.glass-card {
		background: rgba(255, 255, 255, 0.2); /* Trong suốt */
		backdrop-filter: blur(30px) saturate(180%); /* Ép phê độ mờ và rực màu */
		-webkit-backdrop-filter: blur(30px) saturate(180%);
		border: 1px solid rgba(255, 255, 255, 0.4); /* Viền kính siêu mỏng */
		border-radius: 40px;
		width: 100%;
		padding: 60px 20px;
		position: relative;
		transform-style: preserve-3d;
		box-shadow: 0 20px 50px rgba(0,0,0,0.05);
		margin-bottom: 40px;
		text-align: center;
	}

	.card-content h1 { 
		font-size: 2.8rem; font-weight: 800; color: #1e293b;
		transform: translateZ(50px);
	}
	
	.subtitle { 
		font-size: 1rem; color: #475569; margin-top: 10px;
		transform: translateZ(30px);
	}

	.animation-zone {
		height: 180px; display: flex; justify-content: center; align-items: center;
		transform-style: preserve-3d;
	}

	.floating-icon {
		display: inline-block !important; 
		font-size: 80px;
		animation: floatAction 3s ease-in-out infinite;
		transform: translateZ(80px); /* Icon lồi hẳn ra khỏi mặt kính */
	}

	@keyframes floatAction {
		0%, 100% { transform: translateZ(80px) translateY(0px) rotate(0deg); }
		50% { transform: translateZ(80px) translateY(-20px) rotate(5deg); }
	}

	/* Dấu chấm Apple Style */
	.dot-container { display: flex; justify-content: center; gap: 12px; margin-top: 30px; transform: translateZ(20px); }
	.dot {
		width: 12px; height: 12px; border-radius: 50%;
		background-color: rgba(30, 41, 59, 0.1);
		animation: dotWave 3s infinite;
	}
	.dot:nth-child(1) { animation-delay: 0s; }
	.dot:nth-child(2) { animation-delay: 0.3s; }
	.dot:nth-child(3) { animation-delay: 0.6s; }
	.dot:nth-child(4) { animation-delay: 0.9s; }

	@keyframes dotWave {
		0%, 30% { background-color: #0284c7; transform: scale(1.2); }
		40%, 100% { background-color: rgba(30, 41, 59, 0.1); transform: scale(1); }
	}

	.intro-text p { font-size: 1.1rem; color: #334155; }
	.cta-button {
		display: inline-block; margin-top: 20px; padding: 12px 35px;
		background: #1e293b; color: white; text-decoration: none;
		border-radius: 100px; font-weight: 600; font-size: 0.9rem;
	}

	/* Mobile tối ưu */
	@media (max-width: